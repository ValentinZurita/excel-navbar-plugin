{
  "name": "excel-sheet-navigator",
  "version": "0.1.0",
  "private": true,
  "description": "Modern Excel worksheet navigator Office Add-in",
  "scripts": {
    "dev": "webpack serve --mode development",
    "lint": "tsc --noEmit",
    "check:component-imports": "node scripts/check-component-imports.mjs",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:md": "markdownlint-cli2",
    "quality": "npm run check:component-imports && npm run lint:css && npm run lint:md",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/office-js": "^1.0.534",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "jsdom": "^25.0.1",
    "markdownlint-cli2": "^0.15.0",
    "style-loader": "^4.0.0",
    "stylelint": "^16.9.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  }
}
