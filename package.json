{
  "name": "excel-sheet-navigator",
  "version": "0.1.0",
  "private": true,
  "description": "Modern Excel worksheet navigator Office Add-in",
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint",
      "prettier --check"
    ],
    "*.css": [
      "stylelint"
    ],
    "*.md": [
      "markdownlint-cli2"
    ]
  },
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "lint": "tsc --noEmit",
    "check:component-imports": "node scripts/check-component-imports.mjs",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:eslint": "eslint src/ tests/ scripts/",
    "quality": "npm run check:component-imports && npm run lint:css && npm run lint:md && npm run format:check && npm run lint:eslint",
    "manifest:dev": "node scripts/render-manifest.mjs --base-url=https://localhost:3000 --output=manifest.xml",
    "manifest:prod": "node scripts/render-manifest.mjs --output=dist/manifest.xml",
    "manifest:validate": "office-addin-manifest validate dist/manifest.xml",
    "release:check": "node scripts/release-check.mjs",
    "package:release": "npm run release:check && npm run build && npm run manifest:prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:import-cycles": "madge --circular --extensions ts,tsx --ts-config tsconfig.json src/ tests/",
    "check:knip": "knip",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:lockfile-sync": "node scripts/check-lockfile-sync.mjs",
    "check:office-api-requirements": "node scripts/check-office-api-requirements.mjs",
    "check:mock-drift": "node scripts/check-mock-drift.mjs",
    "analyze:bundle": "webpack --mode production --env analyze",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/office-js": "^1.0.534",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.5.0",
    "html-webpack-plugin": "^5.6.3",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^25.0.1",
    "knip": "^5.88.1",
    "lint-staged": "^15.5.2",
    "madge": "^8.0.0",
    "markdownlint-cli2": "^0.15.0",
    "office-addin-manifest": "^2.1.3",
    "prettier": "^3.8.3",
    "style-loader": "^4.0.0",
    "stylelint": "^16.9.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "webpack": "^5.97.1",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  }
}
